{
  "name": "openbentt",
  "productName": "Openbentt",
  "description": "Desktop-first local-first AI workspace (Electron) with optional web OpenRouter chat and Notebook.",
  "author": {
    "name": "Openbentt contributors",
    "email": "openbentt-contributors@users.noreply.github.com"
  },
  "private": true,
  "version": "2.1.0-beta.2",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint . && npm run lint:electron-security && npm run lint:electron-pack",
    "lint:electron-security": "node scripts/check-electron-security.mjs",
    "lint:electron-pack": "node scripts/check-electron-pack-files.mjs",
    "preview": "vite preview",
    "test": "vitest run && npm run test:electron",
    "test:unit": "vitest run",
    "test:electron": "node --test electron/gpuSafeMode.test.mjs electron/llamaBinary.test.mjs electron/researchDb.test.mjs electron/researchVectorStore.test.mjs electron/researchJobQueue.test.mjs electron/researchProjectService.test.mjs electron/researchWorkers/chunkWorker.test.mjs electron/compileArtifactStore.test.mjs src/lib/research/embedCore.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "verify:release": "npm run lint && npm run test && npm run build && npm run test:e2e",
    "verify:release:pack": "npm run build && npm run electron:pack:linux",
    "test:stress": "vitest run src/lib/research/perfStress.test.ts",
    "test:watch": "vitest",
    "research-proxy": "node server/research-proxy.mjs",
    "latex-compile": "node server/latex-compile.mjs",
    "docker:build": "docker build -t openbentt .",
    "docker:up": "docker compose up --build",
    "icons:sync": "convert -background none public/openbentt-logo.svg -resize 512x512 build/icon.png",
    "download:busytex": "texlyre-busytex download-assets public/core",
    "download:llama-server": "node scripts/download-llama-server.mjs",
    "download:llama-server:all": "node scripts/download-llama-server.mjs --all",
    "predownload:llama-server": "node -e \"console.log('Fetching llama-server from ggml-org/llama.cpp releases…')\"",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http-get://127.0.0.1:8080 && cross-env OPENBENTT_ELECTRON_DEV=1 electron .\"",
    "electron:dev:safe": "concurrently -k \"npm run dev\" \"wait-on http-get://127.0.0.1:8080 && cross-env OPENBENTT_ELECTRON_DEV=1 OPENBENTT_DISABLE_GPU=1 electron .\"",
    "electron:start": "npm run build && electron .",
    "electron:start:safe": "npm run build && cross-env OPENBENTT_DISABLE_GPU=1 electron .",
    "electron:build": "npm run build && npm run download:llama-server && electron-builder",
    "electron:build:ci": "npm run build && npm run download:llama-server:all && electron-builder",
    "electron:pack": "electron-builder",
    "electron:pack:linux": "electron-builder --linux --publish never --config.generateUpdatesFilesForAllChannels=true",
    "electron:pack:win": "electron-builder --win --publish never --config.generateUpdatesFilesForAllChannels=true",
    "electron:pack:mac": "electron-builder --mac --publish never --config.generateUpdatesFilesForAllChannels=true"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.9.0",
    "@huggingface/transformers": "^4.0.1",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@react-oauth/google": "^0.12.1",
    "@tanstack/react-query": "^5.56.2",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/uuid": "^10.0.0",
    "@uiw/react-codemirror": "^4.25.10",
    "@vercel/analytics": "^1.5.0",
    "@xenova/transformers": "^2.17.2",
    "citation-js": "^0.7.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "diff": "^9.0.0",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.3.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.2.4",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "katex": "^0.16.45",
    "lucide-react": "^0.462.0",
    "lz-string": "^1.5.0",
    "mathjs": "^13.2.0",
    "next-themes": "^0.3.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.3",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "texlyre-busytex": "^0.1.4-alpha",
    "uuid": "^11.1.0",
    "vaul": "^0.9.3",
    "vercel": "^41.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/diff": "^8.0.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "lovable-tagger": "^1.1.7",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vitest": "^2.1.9",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.openbentt.desktop",
    "productName": "Openbentt",
    "copyright": "Copyright © Openbentt contributors",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/lib/zotero/**/*.mjs",
      "src/lib/research/corpusChunksCore.mjs",
      "src/lib/research/embedCore.mjs",
      "build/icon.png",
      "package.json",
      "node_modules/@xenova/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/onnxruntime-common/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/argparse/**/*",
      "node_modules/sax/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/onnxruntime-node/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "yuvrajpandey77",
        "repo": "SecuredChatCogerphere",
        "releaseType": "release"
      }
    ],
    "generateUpdatesFilesForAllChannels": true,
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "extraResources": [
        {
          "from": "resources/llama/linux",
          "to": "llama/linux",
          "filter": [
            "llama-server",
            ".gitkeep"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "extraResources": [
        {
          "from": "resources/llama/darwin",
          "to": "llama/darwin",
          "filter": [
            "llama-server",
            ".gitkeep"
          ]
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "extraResources": [
        {
          "from": "resources/llama/win32",
          "to": "llama/win32",
          "filter": [
            "llama-server.exe",
            "*.dll",
            ".gitkeep"
          ]
        }
      ]
    }
  }
}
