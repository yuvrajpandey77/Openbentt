# Copy to `.env` for local production builds (`npm run build`). Vite only exposes vars prefixed with VITE_.

# --- Vercel (Project → Settings → Environment Variables, all environments) ---
# Required for production web + /download page:
#   VITE_PUBLIC_SITE_URL=https://your-app.vercel.app   (or custom domain, no trailing slash)
#   VITE_GITHUB_REPO=yuvrajpandey77/SecuredChatCogerphere
# After each desktop release tag (e.g. v2.0.8), set so /download links match GitHub asset names:
#   VITE_DESKTOP_ASSET_VERSION=2.0.8
# Optional:
#   VITE_RESEARCH_PROXY_URL=https://your-proxy.example/api
#   VITE_LATEX_COMPILE_URL=https://your-latex.example/compile
#   VITE_LATEX_REMOTE=1
# Redeploy Vercel after changing any VITE_* var (build-time only).

# --- Recommended for any public deploy (set at build time in CI) ---
# Public origin, no trailing slash. Used for canonical URL, Open Graph / Twitter absolute image URLs.
# VITE_PUBLIC_SITE_URL=https://your.domain

# --- Download page (/download): GitHub Releases + README links ---
# VITE_GITHUB_REPO=yuvrajpandey77/SecuredChatCogerphere
# Optional override if published asset filenames differ from package.json version:
# VITE_DESKTOP_ASSET_VERSION=2.0.8

# --- Optional: research HTTP proxy (Brave search, etc.) ---
# Empty = use in-app Settings URL, or same-origin defaults in Docker (`/api` → nginx → research-proxy).
# Example standalone backend: https://your.host/api
# VITE_RESEARCH_PROXY_URL=

# --- Optional: LaTeX PDF compile (Notebook / full documents) ---
# If unset, the app uses in-browser WASM (BusyTeX) when available, or local `npm run latex-compile` in dev.
# Point to a server that implements POST /compile (see server/latex-compile.mjs).
# VITE_LATEX_COMPILE_URL=
# Set to "1" to skip WASM and use HTTP compile only (when you provide VITE_LATEX_COMPILE_URL or same-origin API).
# VITE_LATEX_REMOTE=
