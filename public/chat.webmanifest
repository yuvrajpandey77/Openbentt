{
  "id": "/chat",
  "name": "Openbentt Chat",
  "short_name": "Obent Chat",
  "description": "OpenRouter AI chat in your browser. API keys stay on your device.",
  "start_url": "/chat",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "any",
  "background_color": "#1f1f1f",
  "theme_color": "#1f1f1f",
  "categories": ["productivity", "utilities"],
  "icons": [
    {
      "src": "/pwa-chat-icon.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/pwa-chat-icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/pwa-chat-icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
